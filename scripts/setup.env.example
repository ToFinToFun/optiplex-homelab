# OptiPlex Homelab - Automation Config
# Kopiera denna fil till setup.env och fyll i värdena innan du kör setup.sh
# Skriptet kan också ställa frågor interaktivt om du lämnar något tomt.

# --- NÄTVERK (Samma subnät som Proxmox-noden) ---
# Exempel: Om din Proxmox har IP 192.168.1.10, sätt nätverk till 192.168.1
NETWORK_PREFIX="192.168.1"
GATEWAY="192.168.1.1"

# --- IP-TILLDELNING ---
# "false" = statiska IP:er (rekommenderat, scriptet verifierar att de är lediga)
# "true"  = DHCP (routern tilldelar IP — du måste låsa dem i routern efterhand!)
USE_DHCP="false"

# IP-adresser för tjänsterna (måste vara lediga i nätverket)
# Dessa blir också ID-numren i Proxmox (t.ex. VM 100)
# Vid DHCP används bara numret som Proxmox-ID (IP tilldelas av routern)
IP_HA="100"          # Blir 192.168.1.100 (vid statisk)
IP_CLOUDFLARED="101" # Blir 192.168.1.101 (vid statisk)
IP_NPM="102"         # Blir 192.168.1.102 (vid statisk)
IP_FRIGATE="103"     # Blir 192.168.1.103 (vid statisk)
IP_ADGUARD="104"    # Blir 192.168.1.104 (vid statisk)

# --- TILLÄGG (valfria, installeras via meny 4) ---
IP_SAMBA="105"       # Blir 192.168.1.105 (vid statisk)
IP_IMMICH="106"      # Blir 192.168.1.106 (vid statisk)
IP_NUT="107"         # Blir 192.168.1.107 (vid statisk)

# Immich-resurser (kräver minst 4GB RAM, 2 kärnor, 50GB disk)
IMMICH_RAM="4096"
IMMICH_DISK="50"
IMMICH_CORES="2"

# --- ADGUARD HOME (DNS) ---
# Upstream DNS: "cloudflare" (Cloudflare DoH, krypterad) eller "router" (använder gateway)
ADGUARD_UPSTREAM="cloudflare"

# --- DOMÄN (för split-DNS och extern åtkomst) ---
# Din domän (t.ex. example.com). Används för split-DNS rewrites i AdGuard
# och för extern åtkomst via Cloudflare Tunnel.
CF_DOMAIN=""

# --- CLOUDFLARE ---
# Token för din Cloudflare Tunnel (den långa strängen från Zero Trust-panelen)
CF_TUNNEL_TOKEN=""

# --- LÖSENORD ---
# Dessa används för att sätta upp containrarna och tjänsterna initialt
CT_PASSWORD="MySecurePassword123!"

# --- HÅRDVARA ---
# Namnet på din storage-pool i Proxmox där CT/VM ska sparas.
# Lämna tomt för att låta skriptet auto-detecta den bästa poolen, 
# eller om du vill att skriptet automatiskt ska formatera en extra SSD.
STORAGE_POOL=""
