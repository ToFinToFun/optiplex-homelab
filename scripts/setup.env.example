# OptiPlex Homelab - Automation Config
# Kopiera denna fil till setup.env och fyll i värdena innan du kör setup.sh
# Skriptet kan också ställa frågor interaktivt om du lämnar något tomt.

# --- NÄTVERK (Samma subnät som Proxmox-noden) ---
# Exempel: Om din Proxmox har IP 192.168.1.10, sätt nätverk till 192.168.1
NETWORK_PREFIX="192.168.1"
GATEWAY="192.168.1.1"

# IP-adresser för tjänsterna (måste vara lediga i nätverket)
# Dessa blir också ID-numren i Proxmox (t.ex. VM 100)
IP_HA="100"          # Blir 192.168.1.100
IP_CLOUDFLARED="101" # Blir 192.168.1.101
IP_NPM="102"         # Blir 192.168.1.102
IP_FRIGATE="103"     # Blir 192.168.1.103

# --- CLOUDFLARE ---
# Token för din Cloudflare Tunnel (den långa strängen från Zero Trust-panelen)
CF_TUNNEL_TOKEN=""

# --- LÖSENORD ---
# Dessa används för att sätta upp containrarna och tjänsterna initialt
CT_PASSWORD="MySecurePassword123!"

# --- HÅRDVARA ---
# Namnet på din storage-pool i Proxmox där CT/VM ska sparas.
# Lämna tomt för att låta skriptet auto-detecta den bästa poolen, 
# eller om du vill att skriptet automatiskt ska formatera en extra SSD.
STORAGE_POOL=""
